        if sym.size == to {
            return sym
        }

        if sym.isReg == false {

        }

        if sym.isFloat {

        } else {
            if sym.size == 1 {
                this.instructions[len(this.instructions)] = asmInstruction {
                    "sxtb", sym, sym
                }

                ogSym = sym
                sym.size = to
                
                if to == 8 {
                    this.instructions[len(this.instructions)] = asmInstruction {
                        "sxtw", sym, ogSym
                    }
                }
            } else if sym.size == 2 {

            } else if sym.size == 4 {

            } else if sym.size == 8 {

            }
            return sym            
        }


    }

}