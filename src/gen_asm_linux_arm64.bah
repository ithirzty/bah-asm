const ASM_OP_BITWISE_RIGHT = 4

const ASM_SELF_OP_ADD = 0
const ASM_SELF_OP_SUB = 1

getTwoPow(x int) int {
    a = 2
    i=1; for a < x, i++ {
        a *= 2
    }

    if a != x {
        return -1
    }

    return i
}

spos(x uint) uint {
    if x == 8 {
        return 1
    }

    return 0
}

_asmSetBitfield(bitfield ptr, index uint) {
    *(<bool*>(<uint>bitfield + index)) = true
}

_asmGetBitfield(bitfield ptr, index uint) bool {
    return *(<bool*>(<uint>bitfield + index))
}

asmRandId uint = 0

struct asmSymbol {
    name: str
    size: uint
    address: int
    offset: int
    level: int
    operStart: int = -1

    isFloat: bool
    isValue: bool
    stack: bool
    isReg: bool
    isTmp: bool
    active: bool

    toStr() str {
        if this.isReg {
            index = 0
            s = ""
            if this.address >= ASM_reg_id_ymm {
                index -= ASM_reg_id_ymm
                s = ASM_float_registers_128[index]
            } else if this.address >= ASM_reg_id_floats {
                index -= ASM_reg_id_floats
                s = ASM_float_registers[spos(this.size)][index]
            } else if this.address >= ASM_reg_id_op {
                index -= ASM_reg_id_op
                s = ASM_registers[spos(this.size)][index + 8]
            } else {
                s = ASM_registers[spos(this.size)][this.address]
            }

            if this.level == 1 {
                return "["+s+"]"
            }

            return s
        }

        return "_undefined_symbol"
    }
}

asmSymbolValue(s str) asmSymbol {
    r = asmSymbol{
        isValue: true
        name: s
        active: true
    }
    return r
}

asmSymbolReg(id uint, size uint, num uint) asmSymbol {
    r = asmSymbol {
        isReg: true
        size: size
        address: id + num
        active: true
    }

    return r
}

asmSymbolStack(address int, size uint) asmSymbol {
    return asmSymbol {
        stack: true
        address: address
        size: size
        active: true
    }
}

asmSymbolStaticName(name str) asmSymbol {
    return asmSymbol {
        name: name
        active: true
    }
}

asmSymbolTmp(size uint) asmSymbol {
    r = asmSymbol {
        stack: true
        isTmp: true
        address: asmRandId
        size: size
        active: true
    }
    asmRandId++
    return r
}

isEmptySymbol(sym asmSymbol*) bool {
    return sym.active == false
}

struct asmInstruction {
    instruction: str
    arg1: asmSymbol
    arg2: asmSymbol

    toStr() str {
        if isEmptySymbol(&this.arg2) == false {
            return this.instruction+" "+this.arg1.toStr()+", "+this.arg2.toStr()
        }
        if isEmptySymbol(&this.arg1) == false {
            return this.instruction+" "+this.arg1.toStr()
        }
        return this.instruction
    }

    //Only works for 4 letters total instructions
    isPrefixedInstruction(id uint) bool {
        return (*<uint*>this.instruction & ~0xFF00000000000000) == id
    }
}

#define _asm_append_instruction(ctxPtr ptr, inst asmInstruction)

struct asmContext {
    staticData: rope*
    data: rope*
    bss: rope*
    code: rope*
    debugInfo: rope*

    debugEnabled: bool = true
    enableOptimizations: bool = true
    instructions: []asmInstruction

    generateDefaults(builtinEnabled bool, isEntryFile bool, importEnabled bool) rope* {
        programEntry rope*
        
        if isEntryFile {
            this.debugInfo = rope(".global .bah_debug_info_lines\n.bah_debug_info_lines:\n")
            this.data = rope("")
            this.bss = rope(".bss\n.global __bss_start\n__bss_start:\n")
            this.code = rope(".text\n")
            if builtinEnabled {
                programEntry = rope(".global _start\n.text\n_start:\nmov x29, sp\nadrp x0, __stackBase\nstr sp, [x0, :lo12:__stackBase]\nbl "+initFnName+"\nldr x0, [sp]\nadd x1, sp, #8\nmov x3, x0\nadd x3, x3, #1\nlsl x3, x3, #3\nadd x2, x1, x3\nbl "+argumentsToArrFunction+"\nbl main\nmov x8, x0\nmov x0, x8\nbl exit\natomic_store:\nldxr x2, [x0]\nstxr w3, x1, [x0]\ncbnz w3, 1b\ndmb ish\nmov x0, x2\nret\natomic_load:\nldar x0, [x0]\nret\natomic_add:\nldxr x2, [x0]\nadd x2, x2, x1\nstxr w3, x2, [x0]\ncbnz w3, 1b\ndmb ish\nret\n"+persistentmcpySource)
                if importEnabled {
                    programEntry += rope(".global atomic_load\n.global atomic_store\n.global atomic_add\n.global __stackBase\n")
                }
                this.staticData = rope(".data\n__stackBase:\n.quad 0\n")
            } else {
                programEntry = rope(".global _start\n.text\n_start:\nmov x29, sp\nadrp x0, __stackBase\nstr sp, [x0, :lo12:__stackBase]\nbl "+initFnName+"\nldr x0, [sp]\nadd x1, sp, #8\nmov x3, x0\nadd x3, x3, #1\nlsl x3, x3, #3\nadd x2, x1, x3\nbl main\nmov x8, x0\nmov x0, x8\nbl exit\n"+persistentmcpySource)
                this.staticData = rope(".data\n__stackBase:\n.quad 0\n")
            }
        } else {
            this.debugEnabled = false
            this.debugInfo = rope("")
            this.staticData = rope(".data\n")
            this.data = rope("")
            this.bss = rope(".bss\n")
            this.code = rope(".text\n")
        }

        return programEntry
    }

    generateOpBitwise(a asmSymbol, b asmSymbol, operation uint, lossy bool) asmSymbol {
        return asmSymbol{}
    }

    staticInt(v str) asmSymbol {
        return asmSymbol {
            name: "#"+intToStr(tokToInt(v))
            size: 8
            isValue: true
            active: true
        }
    }

